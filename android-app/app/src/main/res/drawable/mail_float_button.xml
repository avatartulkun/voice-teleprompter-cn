<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#076163" />
            <stroke android:width="1dp" android:color="#054F51" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#18A4A6"
                android:endColor="#0F8B8D" />
            <stroke android:width="1dp" android:color="#0B7476" />
        </shape>
    </item>
</selector>
