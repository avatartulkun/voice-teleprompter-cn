<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#076163" />
            <stroke android:width="1dp" android:color="#054F51" />
            <padding android:left="8dp" android:right="8dp" android:top="6dp" android:bottom="6dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#B7C4C8" />
            <stroke android:width="1dp" android:color="#9AABAF" />
            <padding android:left="8dp" android:right="8dp" android:top="6dp" android:bottom="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:startColor="#18A4A6"
                android:endColor="#0F8B8D" />
            <stroke android:width="1dp" android:color="#0B7476" />
            <padding android:left="8dp" android:right="8dp" android:top="6dp" android:bottom="6dp" />
        </shape>
    </item>
</selector>
